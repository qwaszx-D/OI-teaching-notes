\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{lecnotes}[2026/04/09 v1.1 Complete Lecture Notes Style]

% --------------------
% 0. 页面布局与超链接 (全打包)
% --------------------
\RequirePackage[
    paperwidth=210mm, paperheight=297mm,
    left=20mm,
    textwidth=155mm,
    marginparsep=5mm,
    marginparwidth=25mm,
    vmargin=25mm
]{geometry}

\RequirePackage{xcolor}
\RequirePackage[dvipsnames, svgnames, x11names]{xcolor}
\RequirePackage{caption}

\RequirePackage{hyperref}
\hypersetup{
    colorlinks=true,
    linkcolor=blue!70!black,
    filecolor=magenta,
    urlcolor=cyan,
    breaklinks=true
}

% --------------------
% 1. 基础宏包
% --------------------
\RequirePackage{amsmath, amssymb, amsthm}
\RequirePackage{etoolbox}
\RequirePackage{enumitem}
\RequirePackage{marginnote}
\RequirePackage{titlesec}
\RequirePackage{listings}
\RequirePackage{tikz}
\RequirePackage{fontawesome5}
\usetikzlibrary{trees, positioning, calc}

% --------------------
% 2. 样式与环境定义
% --------------------
\setlist{nosep} 
\lstset{
    language=C++,
    basicstyle=\ttfamily\small,
    keywordstyle=\color{blue},
    commentstyle=\color{gray},
    numbers=left,
    numberstyle=\tiny,
    breaklines=true,
    frame=single
}
\renewcommand{\lstlistingname}{代码}

% 标题风格
\titleformat{\chapter}[hang]{\huge\bfseries\raggedright}{\thechapter}{1em}{}
\titlespacing{\chapter}{0pt}{-20pt}{20pt}
\titleformat{\section}[hang]{\Large\bfseries\raggedright}{\thesection}{1em}{}
\titleformat{\subsection}[hang]{\large\bfseries\raggedright}{\thesubsection}{1em}{}

% 计数器与 tcolorbox
\RequirePackage[most]{tcolorbox}
\newcounter{maincounter}[chapter]
\renewcommand{\themaincounter}{\thechapter.\arabic{maincounter}}

\tcbset{
    mystyle/.style={
        enhanced, breakable, sharp corners,
        boxrule=0.5pt, fonttitle=\bfseries, coltitle=black,
        attach title to upper, after title={\enspace},
        colback=white, colframe=gray!60,
        left=1mm, right=1mm, top=1mm, bottom=1mm,
    }
}

\newcommand{\formatboxtitle}[2]{%
    #1~\themaincounter\ifblank{#2}{.}{.~#2.}%
}

% 具体的框环境
\newenvironment{example}[1][]{
    \refstepcounter[example]{maincounter}
    \begin{tcolorbox}[mystyle, colframe=red!80!black, title=\formatboxtitle{例}{#1}]
}{\end{tcolorbox}}

\newenvironment{exercise}[1][]{
    \refstepcounter[exercise]{maincounter}
    \begin{tcolorbox}[mystyle, colframe=orange!80!black, title=\formatboxtitle{练习}{#1}]
}{\end{tcolorbox}}

\newenvironment{theorem}[1][]{
    \refstepcounter[theorem]{maincounter}
    \begin{tcolorbox}[mystyle, colframe=blue!80!black, title=\formatboxtitle{定理}{#1}]
}{\end{tcolorbox}}

\newenvironment{lemma}[1][]{
    \refstepcounter[lemma]{maincounter}
    \begin{tcolorbox}[mystyle, colframe=blue!80!black, title=\formatboxtitle{引理}{#1}]
}{\end{tcolorbox}}

\newenvironment{property}[1][]{
    \refstepcounter[property]{maincounter}
    \begin{tcolorbox}[mystyle, colframe=blue!80!black, title=\formatboxtitle{性质}{#1}]
}{\end{tcolorbox}}

\newenvironment{definition}[1][]{
    \refstepcounter[definition]{maincounter}
    \begin{tcolorbox}[mystyle, colframe=green!80!black, title=\formatboxtitle{定义}{#1}]
}{\end{tcolorbox}}

\newenvironment{question}[1][]{
    \refstepcounter[question]{maincounter}
    \begin{tcolorbox}[mystyle, colframe=purple!80!black, title=\formatboxtitle{问题}{#1}]
}{\end{tcolorbox}}

% 1. 章首提要：固定标题，Teal 蓝绿配色
\newenvironment{overview}{
    \begin{tcolorbox}[
        mystyle, 
        colframe=teal!70!black, 
        title=本章提要
        % fontupper=\small,
        % before skip=15pt
    ]
}{\end{tcolorbox}}

% 2. 章末总结：固定标题，SteelBlue 钢蓝配色
\newenvironment{summary}{
    \begin{tcolorbox}[
        mystyle, 
        colframe=blue!50!gray, 
        title=本章总结
        % fontupper=\small,
        % after skip=15pt
    ]
}{\end{tcolorbox}}

\RequirePackage{xparse}
\NewDocumentEnvironment{descbox}{m o}{%
    % #1: 类型（算法/数据结构...）
    % #2: 名称（ST表...）
    \refstepcounter{maincounter}%
    % 关键：手动设置引用时显示的标签名
    \protected@edef\@currentlabelname{#1}% 
    \begin{tcolorbox}[
        mystyle,
        colframe=green!80!black,
        title=\IfValueTF{#2}{\formatboxtitle{#1}{#2}}{\formatboxtitle{#1}{}},
        fontupper=\normalfont,
        breakable
        % before skip=10pt,
        % after skip=10pt
    ]%
}{%
    \end{tcolorbox}
}



\RequirePackage{ocgx2}

% hint 自动计数器
\newcounter{hintcount}
% [2] 表示有两个参数，[提示] 表示第一个参数（可选）的默认值是“提示”
\newenvironment{hint}[1][提示]{%
    \stepcounter{hintcount}%
    % #1 对应可选参数（即点击显示的文字）
    \switchocg{hint-\thehintcount}{\textcolor{blue}{#1\ }}% 
    \begin{ocg}{Hint}{hint-\thehintcount}{0}%
}{%
    \end{ocg}%
}

\newenvironment{solution}[1][解答]{
    \par\noindent{\kaishu #1.}\enspace
}{\par\vspace{0.5em}}

\newtheorem*{remark}{评注}

% 杂项
\newcommand{\graffiti}[2][0pt]{%
    \marginnote[#1]{%
        \small\raggedright
        \normalfont
        \kaishu
        #2%
    }%
}
\newcommand{\pending}{\faHourglassHalf\ }

% --------------------
% 3. 引用自动识别 (必须在最后)
% --------------------
\RequirePackage[nameinlink]{cleveref}
% 引用设置：这里 #1 会显示 "算法 1.1" 这种形式
\crefformat{maincounter}{#2#1#3\,}

\crefformat{figure}{#2图~#1#3\,}
\crefformat{listing}{#2代码~#1#3\,}

\crefformat{example}{#2例~#1#3\,}
\crefformat{exercise}{#2练习~#1#3\,}
\crefformat{lemma}{#2引理~#1#3\,}
\crefformat{theorem}{#2定理~#1#3\,}
\crefformat{property}{#2性质~#1#3\,}
\crefformat{definition}{#2定义~#1#3\,}
\crefformat{question}{#2问题~#1#3\,}
\crefmultiformat{example}{#2例~#1#3\,}{ 和#2#1#3\,}{、#2#1#3\,}{ 和#2#1#3\,}

\endinput